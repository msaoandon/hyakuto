# Copy to .env (gitignored). Every variable the service reads is listed here.

# SQLite file, resolved relative to prisma/schema.prisma.
DATABASE_URL="file:../.data/dev.db"

# Required for sign-in: openssl rand -base64 32
AUTH_SECRET=""

# OAuth providers — each pair optional; an unconfigured provider 400s at
# /v1/auth/start with a clear message. Redirect URIs to register:
#   Google:  http://localhost:3100/v1/auth/callback/google
#   Discord: http://localhost:3100/v1/auth/callback/discord
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
AUTH_DISCORD_ID=""
AUTH_DISCORD_SECRET=""

# Comma-separated app origins allowed for CORS and login-code returns.
# Default: http://localhost:3000
# APP_ORIGINS="http://localhost:3000"
