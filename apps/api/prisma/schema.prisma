// The server-side player save (DEV_PLAN Phase 3). Structured where Phase 4's
// server-authoritative gating will QUERY state (axes, counters, flags, choices,
// completions); opaque JSON where the value is an engine-internal cursor
// (poolSelections, dmRead) or mandated opaque (the MC blob — GDPR posture).
// SQLite locally; the Supabase swap (Phase 4) is a datasource change against a
// stable schema, which is exactly why this lands now.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Player {
  id        String        @id @default(uuid())
  createdAt DateTime      @default(now())
  slots     SaveSlot[]
  accounts  AuthAccount[]
  sessions  ApiSession[]
  codes     LoginCode[]
}

/// An OAuth identity linked to a player. A relation table (not a column on
/// Player): one player can link several providers, and each provider identity
/// carries its own nullable email — Apple hides the real address behind a relay,
/// so no code may ever assume an email exists. A player with zero accounts is a
/// guest.
model AuthAccount {
  provider          String
  providerAccountId String
  player            Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  playerId          String
  email             String?
  displayName       String?
  createdAt         DateTime @default(now())

  @@id([provider, providerAccountId])
}

/// A bearer-token session. The token itself is never stored — only its SHA-256 —
/// so a leaked database cannot impersonate anyone. DB-backed (not a JWT) so
/// sign-out and account deletion revoke for real. Expiry slides on use.
model ApiSession {
  tokenHash  String   @id
  player     Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  playerId   String
  createdAt  DateTime @default(now())
  expiresAt  DateTime
  lastUsedAt DateTime @default(now())
}

/// Single-use, 60-second code minted at the end of the OAuth dance and exchanged
/// (via POST body) for an ApiSession — the bearer token never rides a redirect
/// URL, where it would leak into history and logs. Hashed at rest like tokens.
model LoginCode {
  codeHash          String    @id
  player            Player    @relation(fields: [playerId], references: [id], onDelete: Cascade)
  playerId          String
  provider          String
  providerAccountId String
  expiresAt         DateTime
  consumedAt        DateTime?
}

model SaveSlot {
  id            String   @id @default(uuid())
  player        Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  playerId      String
  slot          Int
  schemaVersion Int
  updatedAt     DateTime @updatedAt
  /// save.gender — a queryable column (address gating), not blob content.
  gender        String
  /// Opaque MC customisation JSON ({ name, pronouns } + mcChosen) — never columns.
  mcBlob        String
  /// Engine-internal cursors — JSON, never queried server-side.
  poolSelections String
  dmRead         String

  axes        AxisValue[]
  counters    CounterValue[]
  flags       FlagSet[]
  choices     ChoiceRecord[]
  completions Completion[]

  @@unique([playerId, slot])
}

model AxisValue {
  slot   SaveSlot @relation(fields: [slotId], references: [id], onDelete: Cascade)
  slotId String
  axis   String
  value  Int

  @@id([slotId, axis])
}

model CounterValue {
  slot    SaveSlot @relation(fields: [slotId], references: [id], onDelete: Cascade)
  slotId  String
  counter String
  value   Int

  @@id([slotId, counter])
}

model FlagSet {
  slot   SaveSlot @relation(fields: [slotId], references: [id], onDelete: Cascade)
  slotId String
  flag   String

  @@id([slotId, flag])
}

model ChoiceRecord {
  slot     SaveSlot @relation(fields: [slotId], references: [id], onDelete: Cascade)
  slotId   String
  choiceId String
  optionId String

  @@id([slotId, choiceId])
}

model Completion {
  slot        SaveSlot @relation(fields: [slotId], references: [id], onDelete: Cascade)
  slotId      String
  threadKey   String
  completedAt BigInt

  @@id([slotId, threadKey])
}
