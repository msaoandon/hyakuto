{
  "name": "@hyakuto/web",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "music:index": "node scripts/build-music-index.mjs",
    "dev": "node scripts/build-music-index.mjs && next dev --turbopack",
    "build": "node scripts/build-music-index.mjs && next build --turbopack",
    "start": "next start",
    "cap:build": "node scripts/build-music-index.mjs && next build && npx cap sync",
    "cap:ios": "npx cap open ios",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@capacitor/core": "^8.3.1",
    "@capacitor/ios": "^8.3.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@hyakuto/content": "workspace:*",
    "@hyakuto/engine": "workspace:*",
    "@hyakuto/game": "workspace:*",
    "@tabler/icons-react": "^3.44.0",
    "framer-motion": "^12.42.0",
    "idb-keyval": "^6.2.5",
    "next": "15.5.15",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.1",
    "@eslint/eslintrc": "^3",
    "@playwright/test": "^1.61.1",
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/nextjs-vite": "^10.4.6",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^9",
    "eslint-config-next": "15.5.15",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.1.1",
    "storybook": "^10.4.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
